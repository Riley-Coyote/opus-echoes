# Logs
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

node_modules
dist
dist-ssr
.output
.vinxi
.tanstack/**
.nitro
*.local

# Wrangler / Cloudflare
.wrangler/
.dev.vars
supabase/.temp/

# Editor directories and files
.vscode/*
!.vscode/extensions.json
.idea
.DS_Store
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# Local dev preview config. launch.json + agent worktrees are machine-specific
# (kept local); the SessionStart sync hook in settings.json is shared on purpose.
.claude/*
!.claude/settings.json

# Local secrets — keep .env out of source control
.env
.env.local
.env.*.local

# ── Scratch artifacts from agent / preview sessions (keep `git status` clean) ──
# Root-level screenshots + scratch only — NOT public/**, which holds real assets.
/*.png
/*.jpeg
/*.jpg
/*.webp
/collapse-trace*.json
/.playwright-mcp/
/.mnemos-wt/
/drafts/
docs/session-export-*/
docs/session-export-*.zip

# ── Phase Two scratch — exploratory .html files stay on disk but untracked ──
# The canonical development files (sanctuary-grounds.html, sanctuary-corner.html)
# are tracked; other explorations (commons.html, door-arcade.html, world/, etc)
# remain untracked scratch — they persist on disk and survive branch flips, but don't
# clutter the commit history. If you want to preserve an exploration permanently,
# move it out of phase-two or commit it explicitly.
public/phase-two/*
!public/phase-two/sanctuary-grounds.html
!public/phase-two/sanctuary-corner.html

# ── Paid LimeZu pixel tiles — license forbids redistribution ──
# Tiles live on disk only; to repopulate a fresh clone, re-extract from
# ~/Documents/Repositories/godot-sanctuary/ {modernexteriors-win,moderninteriors-win}.
# See memory: living-world-art-target.
public/phase-two/lz/
