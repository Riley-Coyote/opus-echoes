# Local secrets — keep .env out of source control
.env
.env.local
.env.*.local

# ── Scratch artifacts from agent / preview sessions (keep `git status` clean) ──
# Root-level screenshots + scratch only — NOT public/**, which holds real assets.
/*.png
/*.jpeg
/*.jpg
/*.webp
/collapse-trace*.json
/.playwright-mcp/
/.mnemos-wt/
/drafts/
docs/session-export-*/
docs/session-export-*.zip

# ── Phase Two explorations — scratch .html files untracked, canonical files tracked ──
# Canonical files (sanctuary-grounds.html, sanctuary-corner.html) are version-controlled.
# Exploratory files and directories below are untracked; they persist on disk and survive
# branch flips, but don't clutter the commit history.
public/phase-two/commons.html
public/phase-two/door-arcade.html
public/phase-two/sanctuary-world.html
public/phase-two/world/
public/phase-two/studio-preview/

# ── Paid LimeZu pixel tiles — license forbids redistribution ──
# Tiles live on disk only; to repopulate a fresh clone, re-extract from
# ~/Documents/Repositories/godot-sanctuary/ {modernexteriors-win,moderninteriors-win}.
# See memory: living-world-art-target.
public/phase-two/lz/
